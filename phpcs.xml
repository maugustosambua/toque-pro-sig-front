<?xml version="1.0"?>
<ruleset name="Toque Pro SiG Front">
    <description>Regras de qualidade PHP para o plugin.</description>

    <rule ref="PSR12" />

    <file>toque-pro-sig.php</file>
    <file>uninstall.php</file>
    <file>core</file>
    <file>database</file>
    <file>helpers</file>
    <file>modules</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="basepath" value="." />
    <arg name="parallel" value="4" />
</ruleset>